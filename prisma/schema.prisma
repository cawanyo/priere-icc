generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Appointment {
  id           String          @id @default(cuid())
  slotId       String          @unique
  leaderId     String
  userId       String
  status       String          @default("CONFIRMED")
  cancelReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  leader       User            @relation("LeaderAppointments", fields: [leaderId], references: [id], onDelete: Cascade)
  slot         AppointmentSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user         User            @relation("UserAppointments", fields: [userId], references: [id], onDelete: Cascade)
}

model AppointmentSlot {
  id          String       @id @default(cuid())
  leaderId    String
  startTime   DateTime
  endTime     DateTime
  isBooked    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  appointment Appointment?
  leader      User         @relation("LeaderSlots", fields: [leaderId], references: [id], onDelete: Cascade)
}

model BlackList {
  id        String   @id
  userId    String
  hour      String
  createdAt DateTime @default(now())
}

model CheckIn {
  id                  String    @id @default(cuid())
  userId              String
  periodMonth         DateTime
  scoreEnergy         Int
  scorePeace          Int
  scoreJoy            Int
  scoreClarity        Int
  scoreServiceLoad    Int
  alerts              String[]
  alertOther          String?
  hadDifficultMoment  Boolean   @default(false)
  difficultMomentText String?
  scoreOvergiving     Int
  scoreSupportFelt    Int
  needsScheduleAdjust Boolean   @default(false)
  supportNeeds        String[]
  consentGiven        Boolean   @default(false)
  visibility          String    @default("TEAM")
  healthScore         Int       @default(0)
  healthStatus        String    @default("GREEN")
  isContacted         Boolean   @default(false)
  leaderNote          String?
  contactedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  comment             String?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodMonth])
}

model EventTemplate {
  id             String       @id @default(cuid())
  title          String
  startTime      String
  endTime        String
  specialEventId String
  specialEvent   SpecialEvent @relation(fields: [specialEventId], references: [id], onDelete: Cascade)
  plannings      Planning[]
}

model FamilyDayTheme {
  id             String                 @id @default(cuid())
  date           DateTime
  theme          String
  assignmentId   String
  assignment     FamilyWeeklyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, date])
}

model FamilySchedule {
  id           String                 @id @default(cuid())
  date         DateTime
  startTime    String
  endTime      String
  assignmentId String
  userId       String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  assignment   FamilyWeeklyAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User?                  @relation(fields: [userId], references: [id])
}

model FamilyWeeklyAssignment {
  id              String           @id @default(cuid())
  weekStart       DateTime         @unique
  familyId        String
  weekTheme       String?
  dayThemes       FamilyDayTheme[]
  schedules       FamilySchedule[]
  prayerFamily    PrayerFamily     @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String?
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

model Planning {
  id             String         @id @default(cuid())
  startTime      String
  endTime        String
  title          String
  description    String?
  recurringId    String?
  specialEventId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  date           DateTime
  templateId     String?
  specialEvent   SpecialEvent?  @relation(fields: [specialEventId], references: [id], onDelete: Cascade)
  eventTemplate  EventTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  users          User[]
}

model Prayer {
  id          String   @id @default(cuid())
  subjectType String
  content     String
  name        String?
  email       String?
  phone       String?
  userId      String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

model PrayerFamily {
  id          String                   @id @default(cuid())
  name        String
  description String?
  color       String                   @default("#4f46e5")
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments FamilyWeeklyAssignment[]
  users       User[]
}

model RecurringSchedule {
  id          String   @id @default(cuid())
  title       String
  description String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoleRequest {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  role      Role     @default(INTERCESSOR)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpecialEvent {
  id             String          @id @default(cuid())
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  eventTemplates EventTemplate[]
  plannings      Planning[]
}

model Testimony {
  id       String           @id @default(cuid())
  name     String
  userId   String?
  content  String?
  audioUrl String?
  status   String           @default("PENDING")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User?           @relation(fields: [userId], references: [id])
  images    TestimonyImage[]
}

model TestimonyImage {
  id          String    @id @default(cuid())
  url         String
  testimonyId String
  testimony   Testimony @relation(fields: [testimonyId], references: [id], onDelete: Cascade)
}

model Unavailability {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  password            String?
  phone               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  role                Role                 @default(REQUESTER)
  prayerFamilyId      String?
  accounts            Account[]
  leaderAppointments  Appointment[]        @relation("LeaderAppointments")
  userAppointments    Appointment[]        @relation("UserAppointments")
  slots               AppointmentSlot[]    @relation("LeaderSlots")
  checkIns            CheckIn[]
  familySchedules     FamilySchedule[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  prayers             Prayer[]
  roleRequest         RoleRequest?
  sessions            Session[]
  testimonies         Testimony[]
  unavailabilities    Unavailability[]
  prayerFamily        PrayerFamily?        @relation(fields: [prayerFamilyId], references: [id])
  plannings           Planning[]
}

enum Role {
  ADMIN
  LEADER
  INTERCESSOR
  REQUESTER
  PRAYER_LEADER
}

enum STATUS {
  PENDING
  APPROVED
  REFUSED
}
